# Your secret NPS Data API key. Get one free at https://www.nps.gov/subjects/developer/get-started.htm
# Copy this file to ".env.local" for local dev, and add the same variable in Vercel
# (Project Settings -> Environment Variables). NEVER commit the real key.
NPS_API_KEY=

# Public Google Maps key (ships to the browser — restrict it to your domain in Google Cloud Console)
NEXT_PUBLIC_GMAPS_KEY=
